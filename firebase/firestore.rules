rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User Private Data ──────────────────────────────────────────────────
    // Each user can only read/write their own document and subcollections.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Personal subcollections: transactions, wallets, groupWallets, budgetLimits, savingGoals
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Groups ──────────────────────────────────────────────────────────────
    // Only group members can read/write group data.
    // Any authenticated user can create a new group.
    // Any authenticated user can query groups by inviteCode (for joining).
    match /groups/{groupId} {

      // Allow creation if the user is authenticated
      // NOTE: Consider adding server-side rate limiting via Cloud Functions
      // if group-creation spam becomes an issue.
      allow create: if request.auth != null;

      // Allow read if the user is a member of the group OR created it (legacy fallback)
      allow read: if request.auth != null
                  && (
                    request.auth.uid in resource.data.memberUids
                    || resource.data.createdBy == request.auth.uid
                    || !("memberUids" in resource.data) && resource.data.createdBy == request.auth.uid
                  );

      // Allow delete only by existing members or creator
      allow delete: if request.auth != null
                    && (request.auth.uid in resource.data.memberUids || resource.data.createdBy == request.auth.uid);

      // SEC-C1: Allow update by existing members or creator
      allow update: if request.auth != null
                    && (
                      request.auth.uid in resource.data.memberUids
                      || resource.data.createdBy == request.auth.uid
                    );

      // Expenses subcollection — members only, and enforce authorship
      match /expenses/{expenseId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
        allow create: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids
                    && request.resource.data.addedBy == request.auth.uid;
        allow update, delete: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids
                    && (!("addedBy" in resource.data) || resource.data.addedBy == request.auth.uid);
      }

      // SEC-C3: Settlements — members only, enforce addedBy on create
      match /settlements/{settlementId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids
                      && request.resource.data.addedBy == request.auth.uid;
        allow update, delete: if request.auth != null
                              && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
      }
    }

    // (Join-by-invite-code logic has been moved to a secure Cloud Function)

    // ─── Default deny ────────────────────────────────────────────────────────
    // Everything else is denied by default (Firestore's default behavior).
  }
}
